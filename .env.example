CROWSYNC_PORT=8001
CROWSYNC_STORAGE_ROOT=/data/storage
CROWSYNC_DB_PATH=/data/crowsync.db
CROWSYNC_LOG_LEVEL=INFO

# Required for adding new members after the first one is created.
# Generate a strong random value, e.g. `python -c "import secrets; print(secrets.token_hex(32))"`.
# The very first member can be created without this token (bootstrap mode).
# (Still needed for destructive ops — delete project/member, change settings —
# even when open registration is on below.)
CROWSYNC_ADMIN_TOKEN=

# Open LAN mode: when "1"/"true", anyone reachable on the network may register
# (or re-register to recover a lost key) with just a name — no admin token.
# Intended for a local/firewalled game-dev team. NEVER enable on a server exposed
# to the public internet. Leave blank/0 to require the admin token above.
CROWSYNC_OPEN_REGISTRATION=

# --- TLS reverse proxy (docker-compose.tls.yml / Caddyfile) ---
# Public domain Caddy serves and requests a Let's Encrypt cert for.
# Leave as localhost for local testing (Caddy issues a locally-trusted cert).
CROWSYNC_DOMAIN=localhost

# Email for Let's Encrypt expiry notices. Optional — leave blank to proceed
# without one (Caddy logs a warning). Ignored when CROWSYNC_DOMAIN=localhost.
CROWSYNC_ACME_EMAIL=
